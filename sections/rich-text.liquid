        },
        {
          "type": "text",
          "id": "img-width",
          "label": "Image Width"
        },
        {
          "type": "text",
          "id": "img-height",
          "label": "Image Height"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Padding top",
          "default": 10
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Padding Bottom",
          "default": 10
        },
        {
          "type": "range",
          "id": "mopadding_top",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Mobile Padding Top",
          "default": 40
        },
        {
          "type": "range",
          "id": "mopadding_bottom",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Mobile Padding Bottom",
          "default": 52
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.rich-text.blocks.buttons.name",
      "limit": 2,
      "settings": [
