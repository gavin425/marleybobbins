        </span>
        {% else %}
          <span class="svg-wrapper">
            {% comment %} {{ 'icon-cart.svg' | inline_asset_content }} {% endcomment %}
             <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
