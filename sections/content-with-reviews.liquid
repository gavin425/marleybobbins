{{ 'content-with-reviews.css' | asset_url | stylesheet_tag }}

<div class="page-width {{section.settings.section-class }}">
    <div class="wrapper">

        {%- if section.settings.pretitle != blank or section.settings.title != blank -%}
            <div class="head theme-text-element">
                {%- if section.settings.pretitle != blank -%}
                    <p class="theme-pretitle">{{ section.settings.pretitle }}</p>
                {%- endif -%}

                {%- if section.settings.title != blank -%}
                    <h2>{{ section.settings.title }}</h2>
                {%- endif -%}
            </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}

            <div class="reviews">
                {%- for block in section.blocks -%}
                    {%- if block.type == 'review' -%}
                        {%- if block.settings.text != blank -%}
                            <div class="review" {{ block.shopify_attributes }}>
                                {% if template.suffix != "trying_to_conceive" %}
                                    <span class="quote-mark" aria-hidden="true"></span>
                                    {% endif %}
                                    <p>{{ block.settings.text }}</p>
                                    {% if block.settings.rtext != blank %}
                                    <p class="style-2">{{ block.settings.rtext }}</p>
                                    {% endif %}
                            </div>
                        {%- endif -%}
                    {%- endif -%}
                {%- endfor -%}
            </div>

            <div class="content theme-text-element">
                {%- for block in section.blocks -%}
                    {%- if block.type == 'text' -%}
                        {%- if block.settings.text != blank -%}
                            <p class="{{ block.settings.style }}" {{ block.shopify_attributes }}>
                                {{ block.settings.text }}
                            </p>
                        {%- endif -%}
                    {%- endif -%}
                {%- endfor -%}
            </div>

        {%- endif -%}

    </div>
</div>
{% if section.settings.heart-icon %}
<span class="heart-icon"></span>
{% endif %}


{% schema %}
{
    "name": "Content with reviews",
    "tag": "section",
    "class": "content-with-reviews-section",
    "settings": [
         {
            "type": "checkbox",
            "id": "heart-icon",
            "label": "Heart Icon",
            "default":true
        },
        {
            "type": "text",
            "id": "section-class",
            "label": "Section Class"
        },
        {
            "type": "text",
            "id": "pretitle",
            "label": "Pre-title"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title"
        }
    ],

    "blocks": [
        {
            "type": "review",
            "name": "Review",
            "settings": [
                {
                    "type": "text",
                    "id": "text",
                    "label": "Text"
                },
                {
                    "type": "text",
                    "id": "rtext",
                    "label": "Text Below"
                }
            ]
        },
        {
            "type": "text",
            "name": "Text",
            "settings": [
                {
                    "type": "text",
                    "id": "text",
                    "label": "Text"
                },
                {
                    "type": "select",
                    "id": "style",
                    "label": "Style",
                    "default": "style-1",
                    "options": [
                        {
                            "value": "style-1",
                            "label": "Style 1"
                        },
                        {
                            "value": "style-2",
                            "label": "Style 2"
                        },
                        {
                            "value": "style-3",
                            "label": "Style 3"
                        }
                    ]
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Content with reviews",
            "blocks": [
                {
                    "type": "review"
                },
                {
                    "type": "review"
                },
                {
                    "type": "review"
                },
                {
                    "type": "text"
                },
                {
                    "type": "text"
                }
            ]
        }
    ]
}
{% endschema %}
