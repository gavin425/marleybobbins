llet_point_RQAxJL":{"type":"bullet-point","settings":{"b-text":"The world women are navigating"}},"heading_nhAf9e":{"type":"heading","settings":{"t-class":"","heading":"Know your body","heading_size":"h1","hpadding_top":70,"hpadding_bottom":0,"mhpadding_top":40,"mhpadding_bottom":0}},"heading_VVq4Yg":{"type":"heading","settings":{"t-class":"","heading":"like never before","heading_size":"h1","hpadding_top":0,"hpadding_bottom":50,"mhpadding_top":0,"mhpadding_bottom":10}},"image_yFr34V":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/stemba-home-noise-information-overload.jpg","img-class":"","b_radius":20,"heart-icon":false,"img-width":"","img-height":"","padding_top":0,"padding_bottom":0,"mopadding_top":0,"mopadding_bottom":30}},"bullet_points_hFpqaT":{"type":"bullet-points","settings":{"b-text1":"<p>Apps predict.<\/p>","b-text2":"<p>Forums contradict each other.<\/p>","b-text3":"<p>TikTok trends change daily.<\/p>","b-text4":"<p>Family expectations and cultural pressures<br\/>add a whole other layer.<\/p>","b-text5":"","b-text6":""}},"liquid_Kp9i6X":{"type":"liquid","settings":{"liquid":"<p class=\"reg\">Stemba exists to bring calm clarity into a space<br>that often feels confusing.<\/p>\n<br>\n<p class=\"m-sb fb\">We're about warm, grounded support<br>and evidence-based options.<\/p>"}},"image_XbgKrb":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Circle_2.svg","img-class":"mobile-hidden","b_radius":10,"heart-icon":false,"img-width":"64","img-height":"20","padding_top":100,"padding_bottom":30,"mopadding_top":40,"mopadding_bottom":52}},"liquid_Ykf7kF":{"type":"liquid","settings":{"liquid":"<p class=\"highlight-text\">We're here to help you understand<br>what your body is telling you, in a<br>clear and human way<\/p>"}}},"block_order":["bullet_point_RQAxJL","heading_nhAf9e","heading_VVq4Yg","image_yFr34V","bullet_points_hFpqaT","liquid_Kp9i6X","image_XbgKrb","liquid_Ykf7kF"],"name":"t:sections.rich-text.presets.name","settings":{"hr_enabl